<%- include('partials/header') %>

    <div class="board-header">
        <div>
            <h1 id="projectName">Loading...</h1>
            <p class="subtitle" style="color: var(--text-muted); font-size: 0.875rem; margin-top: 0.2rem;">Task Board
            </p>
        </div>
        <div id="adminControls" style="display:none;">
            <button id="addTaskBtn" class="btn-primary">+ Add Task</button>
        </div>
    </div>

    <div class="task-board">
        <div class="column col-todo">
            <div class="column-header">
                <h3>To Do</h3>
                <span class="badge badge-accent" id="todoCount">0</span>
            </div>
            <div id="todoCol"></div>
        </div>
        <div class="column col-progress">
            <div class="column-header">
                <h3>In Progress</h3>
                <span class="badge" style="background:var(--warning);color:#fff;" id="progressCount">0</span>
            </div>
            <div id="inProgressCol"></div>
        </div>
        <div class="column col-done">
            <div class="column-header">
                <h3>Done</h3>
                <span class="badge badge-success" id="doneCount">0</span>
            </div>
            <div id="doneCol"></div>
        </div>
    </div>

    <!-- Add Task Modal -->
    <div class="modal" id="taskModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>New Task</h2>
                <button class="modal-close" id="closeTaskModal">✕</button>
            </div>
            <div class="modal-body">
                <div id="taskError" class="error-msg"></div>
                <form id="taskForm">
                    <div class="form-group">
                        <label>Task Title</label>
                        <input type="text" name="title" placeholder="e.g. Design landing page" required>
                    </div>
                    <div class="form-group">
                        <label>Due Date</label>
                        <input type="date" name="dueDate" required>
                    </div>
                    <div class="form-group">
                        <label>Assignee</label>
                        <select name="assignee" id="taskAssignee"></select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="cancelTaskBtn" class="btn-ghost">Cancel</button>
                <button type="submit" form="taskForm" class="btn-primary">Create Task</button>
            </div>
        </div>
    </div>

    <!-- Edit Task Modal -->
    <div class="modal" id="editTaskModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Update Status</h2>
                <button class="modal-close" id="closeEditModal">✕</button>
            </div>
            <div class="modal-body">
                <form id="editTaskForm">
                    <div class="form-group">
                        <label>Status</label>
                        <select name="status">
                            <option value="todo">To Do</option>
                            <option value="in-progress">In Progress</option>
                            <option value="done">Done</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="cancelEditBtn" class="btn-ghost">Cancel</button>
                <button type="submit" form="editTaskForm" class="btn-primary">Save Changes</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>