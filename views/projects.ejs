<%- include('partials/header') %>

    <div class="page-header">
        <div>
            <h1>My Projects</h1>
            <p class="subtitle">Manage your teams and projects</p>
        </div>
        <button id="createProjectBtn" class="btn-primary">+ New Project</button>
    </div>

    <div id="projectList" class="project-grid">
        <div class="loading-text">Loading projects...</div>
    </div>

    <!-- Create Project Modal -->
    <div class="modal" id="projectModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>New Project</h2>
                <button class="modal-close" id="closeProjectModal">✕</button>
            </div>
            <div class="modal-body">
                <div id="projectError" class="error-msg"></div>
                <form id="projectForm">
                    <div class="form-group">
                        <label>Project Name</label>
                        <input type="text" name="name" placeholder="e.g. Website Redesign" required>
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="description" placeholder="Brief description of the project..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" id="cancelProjectBtn" class="btn-ghost">Cancel</button>
                <button type="submit" form="projectForm" class="btn-primary">Create Project</button>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>